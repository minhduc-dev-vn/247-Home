# Local demo values only. Never reuse these credentials outside this machine.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=home247
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/home247?schema=public

# Replace when sharing a demo environment. This checked-in value is intentionally
# public and must never be treated as a production secret.
AUTH_SECRET=local-demo-only-auth-secret-change-before-sharing-247-home
AUTH_URL=http://127.0.0.1:3000
APP_ORIGIN=http://127.0.0.1:3000
APP_PORT=3000

# STORAGE_CONFIG documents the aggregate local contract. Compose expands the
# individual variables below because the application validates each field.
STORAGE_CONFIG={"provider":"s3","bucket":"247-home-demo","region":"us-east-1","endpoint":"http://storage:9000","forcePathStyle":true}
STORAGE_BUCKET=247-home-demo
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=local-demo-minio-password
STORAGE_FORCE_PATH_STYLE=true
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

LOCAL_DEMO=true
DEMO_RESET_ALLOWED=true
RATE_LIMIT_BACKEND=memory
