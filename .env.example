# Local-only PostgreSQL configuration. Do not use these values in production.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/home247?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="home247"
# Generate a local value with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# Keep this blank in the example and never commit a generated value.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
APP_ORIGIN="http://localhost:3000"
TRUST_PROXY_HEADERS="false"
AUTH_SECURE_COOKIES="false"

# Evidence storage. Local is development/test only and is rejected when
# NODE_ENV=production. Staging must use the S3-compatible provider.
EVIDENCE_STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_FORCE_PATH_STYLE="false"
